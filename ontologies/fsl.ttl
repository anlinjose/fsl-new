@prefix : <http://www.softlang.org/ontologies/sle/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://www.softlang.org/ontologies/sle/> .

#################################################################
# Ontology
#################################################################

<http://www.softlang.org/ontologies/sle>
	rdf:type owl:Ontology ;
	rdfs:comment "Taxonomy of software language engineering formalisms and approaches"@en .

#################################################################
# Classes (categories)
#################################################################

:SoftwareLanguage
    a owl:Class ;
    rdfs:label "Software language"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Software_language> ;
    rdfs:comment "language used in software development"@en .

:FormalGrammar
    a owl:Class ;
    rdfs:label "Formal grammar"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Formal_grammar> ;
    rdfs:comment "formal grammar for languages"@en .

:GenerativeGrammar
    a owl:Class ;
    rdfs:label "Generative grammar"@en ;
    rdfs:subClassOf :FormalGrammar ;
    owl:sameAs <https://en.wikipedia.org/wiki/Formal_grammar#The_Chomsky_hierarchy> ;
    rdfs:comment "grammar generating valid strings"@en .

:AnalyticGrammar
    a owl:Class ;
    rdfs:label "Analytic grammar"@en ;
    rdfs:subClassOf :FormalGrammar ;
    owl:sameAs <https://en.wikipedia.org/wiki/Formal_grammar#Analytic_grammars> ;
    rdfs:comment "grammar recognizing valid strings"@en .

:Metalanguage
    a owl:Class ;
    rdfs:label "Metalanguage"@en ;
    rdfs:subClassOf :SoftwareLanguage ;
    owl:sameAs <https://en.wikipedia.org/wiki/Metalanguage> ;
    rdfs:comment "language for describing languages"@en .

:FormalSystem
    a owl:Class ;
    rdfs:label "Formal system"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Formal_system> ;
    rdfs:comment "symbolic deductive formal system"@en .

:LambdaCalculus
    a owl:Class ;
    rdfs:label "Lambda calculus"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Lambda_calculus> ;
    rdfs:comment "formalism for function abstraction"@en .

:LambdaCube
    a owl:Class ;
    rdfs:label "Lambda cube"@en ;
    rdfs:subClassOf :LambdaCalculus ;
    owl:sameAs <https://en.wikipedia.org/wiki/Lambda_cube> ;
    rdfs:comment "typed lambda calculus family"@en .

:TypeTheory
    a owl:Class ;
    rdfs:label "Type theory"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Type_theory> ;
    rdfs:comment "formal theory of types"@en .

:FormalSemanticsApproach
    a owl:Class ;
    rdfs:label "Formal semantics approach"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Semantics_(programming_languages)#Approaches> ;
    rdfs:comment "approach to programming language semantics"@en .

:MetaprogrammingApproach
    a owl:Class ;
    rdfs:label "Metaprogramming approach"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Metaprogramming> ;
    rdfs:comment "approach based on programs manipulating programs"@en .

:ProgramTransformationApproach
    a owl:Class ;
    rdfs:label "Program transformation approach"@en ;
    rdfs:subClassOf :MetaprogrammingApproach ;
    owl:sameAs <https://en.wikipedia.org/wiki/Program_transformation> ;
    rdfs:comment "approach for transforming programs"@en .

:SyntaxDirectedTranslationApproach
    a owl:Class ;
    rdfs:label "Syntax-directed translation approach"@en ;
    rdfs:subClassOf :MetaprogrammingApproach ;
    owl:sameAs <https://en.wikipedia.org/wiki/Syntax-directed_translation> ;
    rdfs:comment "approach driven by syntax structure"@en .

:ProgramLogic
    a owl:Class ;
    rdfs:label "Program logic"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Category:Program_logic> ;
    rdfs:comment "logic for reasoning about programs"@en .

:DescriptionLogic
    a owl:Class ;
    rdfs:label "Description logic"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Description_logic> ;
    rdfs:comment "logic family for structured knowledge"@en .

:ProcessCalculus
    a owl:Class ;
    rdfs:label "Process calculus"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Process_calculus> ;
    rdfs:comment "calculus for concurrent processes"@en .

:AbstractRewritingSystem
    a owl:Class ;
    rdfs:label "Abstract rewriting system"@en ;
    rdfs:subClassOf :FormalSystem ;
    owl:sameAs <https://en.wikipedia.org/wiki/Abstract_rewriting_system> ;
    rdfs:comment "abstract formal rewriting framework"@en .

:ModelingLanguage
    a owl:Class ;
    rdfs:label "Modeling language"@en ;
    rdfs:subClassOf :SoftwareLanguage ;
    owl:sameAs <https://en.wikipedia.org/wiki/Modeling_language> ;
    rdfs:comment "language for modeling systems"@en .

#################################################################
# Individuals (entities)
#################################################################

:ContextFreeGrammar
    a owl:NamedIndividual , :GenerativeGrammar ;
    rdfs:label "Context-free grammar"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Context-free_grammar> ;
    rdfs:comment "grammar with context-free productions"@en .

:ParsingExpressionGrammar
    a owl:NamedIndividual , :AnalyticGrammar ;
    rdfs:label "Parsing expression grammar"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Parsing_expression_grammar> ;
    rdfs:comment "recognition-based formal grammar"@en .

:ExtendedBackusNaurForm
    a owl:NamedIndividual , :Metalanguage ;
    rdfs:label "Extended Backus-Naur form"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Extended_Backus-Naur_form> ;
    rdfs:comment "metalanguage for grammar notation"@en .

:RegularGrammar
    a owl:NamedIndividual , :GenerativeGrammar ;
    rdfs:label "Regular grammar"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Regular_grammar> ;
    rdfs:comment "grammar for regular languages"@en .

:AttributeGrammar
    a owl:NamedIndividual , :FormalGrammar , :SyntaxDirectedTranslationApproach ;
    rdfs:label "Attribute grammar"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Attribute_grammar> ;
    rdfs:comment "grammar with attributes and rules"@en .

:TermRewritingSystem
    a owl:NamedIndividual , :AbstractRewritingSystem , :ProgramTransformationApproach ;
    rdfs:label "Term rewriting system"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Rewriting#Term_rewriting_systems> ;
    rdfs:comment "rewriting system over algebraic terms"@en .

:UntypedLambdaCalculus
    a owl:NamedIndividual , :LambdaCalculus ;
    rdfs:label "Untyped lambda calculus"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Lambda_calculus> ;
    rdfs:comment "lambda calculus without types"@en .

:SimplyTypedLambdaCalculus
    a owl:NamedIndividual , :LambdaCube , :TypeTheory ;
    rdfs:label "Simply typed lambda calculus"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Simply_typed_lambda_calculus> ;
    rdfs:comment "typed lambda calculus with simple types"@en .

:SystemF
    a owl:NamedIndividual , :LambdaCube , :TypeTheory ;
    rdfs:label "System F"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/System_F> ;
    rdfs:comment "polymorphic typed lambda calculus"@en .

:DenotationalSemantics
    a owl:NamedIndividual , :FormalSemanticsApproach ;
    rdfs:label "Denotational semantics"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Denotational_semantics> ;
    rdfs:comment "semantics via mathematical denotations"@en .

:OperationalSemantics
    a owl:NamedIndividual , :FormalSemanticsApproach ;
    rdfs:label "Operational semantics"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Operational_semantics> ;
    rdfs:comment "semantics via execution steps"@en .

:AxiomaticSemantics
    a owl:NamedIndividual , :FormalSemanticsApproach ;
    rdfs:label "Axiomatic semantics"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Axiomatic_semantics> ;
    rdfs:comment "semantics via logical axioms"@en .

:CommunicatingSequentialProcesses
    a owl:NamedIndividual , :ProcessCalculus ;
    rdfs:label "Communicating sequential processes"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Communicating_sequential_processes> ;
    rdfs:comment "process algebra for communication"@en .

:CalculusOfCommunicatingSystems
    a owl:NamedIndividual , :ProcessCalculus ;
    rdfs:label "Calculus of communicating systems"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Calculus_of_communicating_systems> ;
    rdfs:comment "calculus for communicating concurrent systems"@en .

:UMLStateMachine
    a owl:NamedIndividual , :ModelingLanguage ;
    rdfs:label "UML state machine"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/UML_state_machine> ;
    rdfs:comment "behavioral state machine notation in UML"@en .

:HoareLogic
    a owl:NamedIndividual , :ProgramLogic ;
    rdfs:label "Hoare logic"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Hoare_logic> ;
    rdfs:comment "program logic using Hoare triples"@en .

:DependencyGrammar
    a owl:NamedIndividual , :FormalGrammar ;
    rdfs:label "Dependency grammar"@en ;
    owl:sameAs <https://en.wikipedia.org/wiki/Dependency_grammar> ;
    rdfs:comment "grammar based on dependency relations"@en .
