@prefix : <http://www.softlang.org/ontologies/te#> .
@prefix ae: <http://www.softlang.org/ontologies/ae#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix le: <http://www.softlang.org/ontologies/le#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pe: <http://www.softlang.org/ontologies/pe#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .

<http://www.softlang.org/ontologies/te> a owl:Ontology ;
    tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    rdfs:comment "Sub-ontology / ABox for software tools"@en ;
    owl:imports <http://www.softlang.org/ontologies/pe>,
        <http://www.softlang.org/ontologies/tbox> .

:APIWorkbench a tbox:ToolEntity ;
    rdfs:label "API workbench"@en ;
    tbox:hasAffectedArtifact ae:APIDescriptionArtifact ;
    tbox:hasInputArtifact ae:APIDescriptionArtifact ;
    tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
    tbox:processes ae:APIDescriptionArtifact ;
    tbox:supports le:InterfaceDescriptionLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:BuildTool a tbox:ToolEntity ;
    rdfs:label "Build tool"@en ;
    tbox:hasInputArtifact ae:BuildScriptArtifact,
        ae:ConfigurationArtifact ;
    tbox:supports le:BuildScriptingLanguage,
        le:ConfigurationLanguage ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/wiki/Build_automation> .

:Compiler a tbox:ToolEntity ;
    rdfs:label "Compiler"@en ;
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:processes ae:ProgramArtifact ;
    tbox:supports pe:ProgrammingLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:ConfigurationTool a tbox:ToolEntity ;
    rdfs:label "Configuration tool"@en ;
    tbox:hasAffectedArtifact ae:ConfigurationArtifact ;
    tbox:hasInputArtifact ae:ConfigurationArtifact ;
    tbox:hasOutputArtifact ae:ConfigurationArtifact ;
    tbox:supports le:ConfigurationLanguage ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/wiki/Configuration_management> .

:Database a tbox:ToolEntity ;
    rdfs:label "Database"@en ;
    rdfs:comment "software tool for storing, organizing, and retrieving data"@en ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/wiki/Database> .

:GrammarAnalyzer a tbox:ToolEntity ;
    rdfs:label "Grammar analyzer"@en ;
    tbox:processes ae:GrammarArtifact ;
    tbox:supports le:GrammarMetalanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:GrammarTransformationEngine a tbox:ToolEntity ;
    rdfs:label "Grammar transformation engine"@en ;
    tbox:processes ae:GrammarArtifact ;
    tbox:supports le:GrammarTransformationLanguage ;
    rdfs:subClassOf :TransformationEngine .

:GraphDatabase a tbox:ToolEntity ;
    rdfs:label "Graph database"@en ;
    tbox:hasSpace ce:Graphware ;
    rdfs:comment "database specialized for storing and querying graph-structured data"@en ;
    rdfs:subClassOf :Database ;
    foaf:page <https://en.wikipedia.org/wiki/Graph_database> .

:GraphDatabaseManagementSystem a tbox:ToolEntity ;
    rdfs:label "Graph database management system"@en ;
    tbox:hasSpace ce:Graphware ;
    tbox:processes ae:GraphQueryArtifact,
        ae:PropertyGraphArtifact ;
    tbox:supports le:GraphQueryLanguage,
        le:PropertyGraphDataModelLanguage ;
    rdfs:subClassOf :GraphDatabase,
        :QueryProcessor .

:Interpreter a tbox:ToolEntity ;
    rdfs:label "Interpreter"@en ;
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:processes ae:ProgramArtifact ;
    tbox:supports pe:ProgrammingLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:JSONProcessor a tbox:ToolEntity ;
    rdfs:label "JSON processor"@en ;
    tbox:processes ae:JSONDocumentArtifact,
        ae:JSONSchemaArtifact ;
    tbox:supports le:JSON,
        le:JSONQueryLanguage,
        le:JSONSchemaLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:LogicProgrammingSystem a tbox:ToolEntity ;
    rdfs:label "Logic programming system"@en ;
    tbox:processes ae:LogicProgramArtifact ;
    tbox:supports pe:Datalog,
        pe:Prolog ;
    rdfs:subClassOf tbox:SoftwareTool .

:MarkupProcessor a tbox:ToolEntity ;
    rdfs:label "Markup processor"@en ;
    tbox:processes ae:MarkupArtifact ;
    tbox:supports le:MarkupLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:ModelingWorkbench a tbox:ToolEntity ;
    rdfs:label "Modeling workbench"@en ;
    tbox:processes ae:MetamodelArtifact,
        ae:ModelArtifact ;
    tbox:supports le:MetamodelingLanguage,
        le:ModelingLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:ModelTransformationEngine a tbox:ToolEntity ;
    rdfs:label "Model transformation engine"@en ;
    tbox:hasInputArtifact ae:MetamodelArtifact,
        ae:ModelArtifact ;
    tbox:hasOutputArtifact ae:ModelArtifact ;
    tbox:processes ae:MetamodelArtifact,
        ae:ModelArtifact ;
    tbox:supports le:ModelTransformationLanguage ;
    rdfs:subClassOf :TransformationEngine .

:ModelValidator a tbox:ToolEntity ;
    rdfs:label "Model validator"@en ;
    tbox:processes ae:ModelArtifact ;
    tbox:supports le:ConstraintLanguage ;
    rdfs:subClassOf :Validator .

:OntologyEditor a tbox:ToolEntity ;
    rdfs:label "Ontology editor"@en ;
    tbox:processes ae:OntologyArtifact ;
    tbox:supports le:OntologyLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:ParserGenerator a tbox:ToolEntity ;
    rdfs:label "Parser generator"@en ;
    tbox:processes ae:GrammarArtifact ;
    tbox:supports le:GrammarMetalanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:ProofAssistant a tbox:ToolEntity ;
    rdfs:label "Proof assistant"@en ;
    tbox:hasAffectedArtifact ae:ProofArtifact ;
    tbox:hasInputArtifact ae:ProofArtifact ;
    tbox:hasOutputArtifact ae:ProofArtifact ;
    tbox:processes ae:ProofArtifact ;
    tbox:supports le:ProofLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:QueryProcessor a tbox:ToolEntity ;
    rdfs:label "Query processor"@en ;
    rdfs:subClassOf tbox:SoftwareTool .

:Reasoner a tbox:ToolEntity ;
    rdfs:label "Reasoner"@en ;
    tbox:processes ae:OntologyArtifact,
        ae:RDFGraphArtifact ;
    tbox:supports le:OntologyLanguage,
        le:SemanticDataModelLanguage ;
    rdfs:subClassOf tbox:SoftwareTool,
        :SemanticReasoner .

:RefactoringTool a tbox:ToolEntity ;
    rdfs:label "Refactoring tool"@en ;
    tbox:hasAffectedArtifact ae:ProgramArtifact ;
    tbox:supports pe:ProgrammingLanguage ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/wiki/Code_refactoring> .

:RelationalDatabaseManagementSystem a tbox:ToolEntity ;
    rdfs:label "Relational database management system"@en ;
    tbox:processes ae:RelationalDataArtifact,
        ae:RelationalQueryArtifact,
        ae:RelationalSchemaArtifact ;
    tbox:supports le:SQL,
        le:SQLDDL,
        le:SQLDML,
        le:SQLQuery ;
    rdfs:subClassOf :QueryProcessor,
        :Validator .

:RequirementsTool a tbox:ToolEntity ;
    rdfs:label "Requirements tool"@en ;
    tbox:hasAffectedArtifact ae:RequirementsArtifact ;
    tbox:hasInputArtifact ae:RequirementsArtifact ;
    tbox:hasOutputArtifact ae:RequirementsArtifact ;
    tbox:supports le:RequirementsSpecificationLanguage ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/wiki/Requirements_engineering> .

:RuleEngine a tbox:ToolEntity ;
    rdfs:label "Rule engine"@en ;
    tbox:hasSpace ce:Ruleware ;
    tbox:processes ae:RuleArtifact ;
    tbox:supports le:RuleLanguage ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/?title=Rule_engine&redirect=no> .

:SemanticReasoner a tbox:ToolEntity ;
    rdfs:label "Semantic reasoner"@en ;
    tbox:hasSpace ce:Logicware,
        ce:Ontoware ;
    rdfs:comment "software tool for inferring logical consequences from semantic data and ontologies"@en ;
    rdfs:subClassOf tbox:SoftwareTool ;
    foaf:page <https://en.wikipedia.org/wiki/Semantic_reasoner> .

:StaticAnalyzer a tbox:ToolEntity ;
    rdfs:label "Static analyzer"@en ;
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:processes ae:ProgramArtifact ;
    tbox:supports pe:ProgrammingLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:TransformationEngine a tbox:ToolEntity ;
    rdfs:label "Transformation engine"@en ;
    rdfs:subClassOf tbox:SoftwareTool .

:TripleStore a tbox:ToolEntity ;
    rdfs:label "Triple store"@en ;
    tbox:processes ae:RDFGraphArtifact ;
    tbox:supports le:RDF,
        le:SPARQL ;
    rdfs:subClassOf :QueryProcessor .

:Validator a tbox:ToolEntity ;
    rdfs:label "Validator"@en ;
    rdfs:subClassOf tbox:SoftwareTool .

:XMLProcessor a tbox:ToolEntity ;
    rdfs:label "XML processor"@en ;
    tbox:processes ae:XMLDocumentArtifact,
        ae:XMLSchemaArtifact ;
    tbox:supports le:DocumentTransformationLanguage,
        le:XML,
        le:XMLQueryLanguage,
        le:XMLSchemaLanguage ;
    rdfs:subClassOf tbox:SoftwareTool .

:Ansible a tbox:ToolEntity,
        :ConfigurationTool,
        owl:NamedIndividual ;
    rdfs:label "Ansible"@en ;
    rdfs:comment "configuration automation tool commonly used with YAML-based configuration artifacts"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Ansible_(software)> .

:ANTLR a tbox:ToolEntity,
        :ParserGenerator,
        owl:NamedIndividual ;
    rdfs:label "ANTLR"@en ;
    rdfs:comment "parser generator based on grammar notation with semantic and syntactic processing support"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/ANTLR> .

:ApacheJena a tbox:ToolEntity,
        :Reasoner,
        :TripleStore,
        owl:NamedIndividual ;
    rdfs:label "Apache Jena"@en ;
    rdfs:comment "framework for RDF storage, SPARQL processing, and reasoning"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Apache_Jena> .

:ATLTransformationEngine a tbox:ToolEntity,
        :ModelTransformationEngine,
        owl:NamedIndividual ;
    rdfs:label "ATL transformation engine"@en ;
    rdfs:comment "engine for executing ATL model transformations"@en ;
    foaf:page <https://eclipse.dev/atl/> .

:BaseX a tbox:ToolEntity,
        :QueryProcessor,
        :XMLProcessor,
        owl:NamedIndividual ;
    rdfs:label "BaseX"@en ;
    rdfs:comment "XML database and XQuery processor"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/BaseX> .

:Bison a tbox:ToolEntity,
        :ParserGenerator,
        owl:NamedIndividual ;
    rdfs:label "Bison"@en ;
    rdfs:comment "parser generator for context-free grammars"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GNU_Bison> .

:CoqProofAssistant a tbox:ToolEntity,
        :ProofAssistant,
        owl:NamedIndividual ;
    rdfs:label "Coq proof assistant"@en ;
    rdfs:comment "proof assistant for interactive theorem proving based on dependent type theory"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Coq> .

:CPython a tbox:ToolEntity,
        :Interpreter,
        owl:NamedIndividual ;
    rdfs:label "CPython"@en ;
    rdfs:comment "reference interpreter implementation of the Python programming language"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/CPython> .

:Drools a tbox:ToolEntity,
        :RuleEngine,
        owl:NamedIndividual ;
    rdfs:label "Drools"@en ;
    rdfs:comment "rule engine and business rule management system"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Drools> .

:EclipseIDE a tbox:ToolEntity,
        :RefactoringTool,
        owl:NamedIndividual ;
    rdfs:label "Eclipse IDE"@en ;
    rdfs:comment "integrated development environment with refactoring support"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Eclipse_(software)> .

:EclipseModelingFramework a tbox:ToolEntity,
        :ModelingWorkbench,
        owl:NamedIndividual ;
    rdfs:label "Eclipse Modeling Framework"@en ;
    rdfs:comment "modeling workbench for Ecore-based models and metamodels"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Eclipse_Modeling_Framework> .

:GCC a tbox:ToolEntity,
        :Compiler,
        owl:NamedIndividual ;
    rdfs:label "GCC"@en ;
    rdfs:comment "compiler collection for several programming languages"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GNU_Compiler_Collection> .

:GNUMake a tbox:ToolEntity,
        :BuildTool,
        owl:NamedIndividual ;
    rdfs:label "GNU Make"@en ;
    rdfs:comment "build automation tool for executing Makefile-based build specifications"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GNU_Make> .

:GraphDB a tbox:ToolEntity,
        :Reasoner,
        :TripleStore,
        owl:NamedIndividual ;
    rdfs:label "GraphDB"@en ;
    rdfs:comment "semantic graph database with RDF storage and reasoning support"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/GraphDB> .

:IBMDOORS a tbox:ToolEntity,
        :RequirementsTool,
        owl:NamedIndividual ;
    rdfs:label "IBM DOORS"@en ;
    rdfs:comment "requirements management tool for capturing and organizing requirements artifacts"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/IBM_DOORS> .

:LeanProofAssistant a tbox:ToolEntity,
        :ProofAssistant,
        owl:NamedIndividual ;
    rdfs:label "Lean proof assistant"@en ;
    rdfs:comment "proof assistant and programming environment for mechanized reasoning"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Lean_(proof_assistant)> .

:Neo4j a tbox:ToolEntity,
        :GraphDatabaseManagementSystem,
        owl:NamedIndividual ;
    rdfs:label "Neo4j"@en ;
    rdfs:comment "graph database management system for property graphs"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Neo4j> .

:PostgreSQL a tbox:ToolEntity,
        :RelationalDatabaseManagementSystem,
        owl:NamedIndividual ;
    rdfs:label "PostgreSQL"@en ;
    rdfs:comment "relational database management system"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/PostgreSQL> .

:Protege a tbox:ToolEntity,
        :OntologyEditor,
        owl:NamedIndividual ;
    rdfs:label "Protégé"@en ;
    rdfs:comment "ontology editor and knowledge-modeling environment"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Prot%C3%A9g%C3%A9_(software)> .

:Saxon a tbox:ToolEntity,
        :QueryProcessor,
        :TransformationEngine,
        :XMLProcessor,
        owl:NamedIndividual ;
    rdfs:label "Saxon"@en ;
    rdfs:comment "processor for XSLT, XQuery, and XPath"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Saxon_XSLT> .

:SonarQube a tbox:ToolEntity,
        :StaticAnalyzer,
        owl:NamedIndividual ;
    rdfs:label "SonarQube"@en ;
    rdfs:comment "static analysis platform for inspecting source code quality"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/SonarQube> .

:SwaggerEditor a tbox:ToolEntity,
        :APIWorkbench,
        owl:NamedIndividual ;
    rdfs:label "Swagger Editor"@en ;
    rdfs:comment "tool for authoring and validating OpenAPI descriptions"@en ;
    foaf:page <https://en.wikipedia.org/wiki/Swagger_(software)> .

:SWIProlog a tbox:ToolEntity,
        :LogicProgrammingSystem,
        owl:NamedIndividual ;
    rdfs:label "SWI-Prolog"@en ;
    rdfs:comment "logic programming system for Prolog and related symbolic reasoning tasks"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/SWI-Prolog> .

:JSONProcessor owl:disjointWith :XMLProcessor .

[ a owl:AllDisjointClasses ;
    owl:members ( :Reasoner :ParserGenerator :ProofAssistant :RefactoringTool :RequirementsTool ) ] .
